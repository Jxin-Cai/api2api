{
  "protocolType": "AWS_BEDROCK_CONVERSE",
  "displayName": "AWS Bedrock Converse",
  "apiSpecVersion": "Bedrock Runtime 2023-09-30",
  "description": "AWS Bedrock Converse API，AWS 统一的多模型对话接口，支持工具调用、推理、流式响应、文档/图片输入、Guardrails 等能力。仅作为上游协议使用。",
  "defaultEndpointPath": "/model/{modelId}/converse",
  "fields": [
    {"fieldName": "messages", "fieldPath": "messages", "fieldType": "ARRAY", "required": true, "section": "MESSAGE", "usageDirection": "INPUT", "description": "对话消息列表", "purpose": "承载多轮对话上下文", "usageContext": "数组元素包含 role（user/assistant）和 content 字段"},
    {"fieldName": "messages[].role", "fieldPath": "messages[].role", "fieldType": "STRING", "required": true, "section": "MESSAGE", "usageDirection": "INPUT", "description": "消息角色：user、assistant", "purpose": "标识消息发送方", "usageContext": "Bedrock 仅支持 user 和 assistant 两种角色"},
    {"fieldName": "messages[].content", "fieldPath": "messages[].content", "fieldType": "ARRAY", "required": true, "section": "MESSAGE", "usageDirection": "INPUT", "description": "内容块数组", "purpose": "承载消息的实际内容", "usageContext": "支持 text、image、document、toolUse、toolResult 类型的内容块"},
    {"fieldName": "system", "fieldPath": "system", "fieldType": "ARRAY", "required": false, "section": "MESSAGE", "usageDirection": "INPUT", "description": "系统提示词内容块列表", "purpose": "设定模型行为", "usageContext": "内容块数组形式，支持文本和 guardContent"},
    {"fieldName": "system[].text", "fieldPath": "system[].text", "fieldType": "STRING", "required": false, "section": "MESSAGE", "usageDirection": "INPUT", "description": "系统提示词文本", "purpose": "以文本形式设定系统指令", "usageContext": "最常用的系统提示方式"},
    {"fieldName": "system[].guardContent", "fieldPath": "system[].guardContent", "fieldType": "OBJECT", "required": false, "section": "MESSAGE", "usageDirection": "INPUT", "description": "Guardrails 保护内容", "purpose": "传递需要 Guardrail 评估的内容", "usageContext": "与 guardrailConfig 配合使用"},
    {"fieldName": "output", "fieldPath": "output", "fieldType": "OBJECT", "required": true, "section": "MESSAGE", "usageDirection": "OUTPUT", "description": "响应输出对象", "purpose": "承载模型生成的内容", "usageContext": "包含 message 字段"},
    {"fieldName": "output.message", "fieldPath": "output.message", "fieldType": "OBJECT", "required": true, "section": "MESSAGE", "usageDirection": "OUTPUT", "description": "响应消息对象", "purpose": "包含模型的实际回复", "usageContext": "包含 role（assistant）和 content 内容块数组"},
    {"fieldName": "output.message.role", "fieldPath": "output.message.role", "fieldType": "STRING", "required": true, "section": "MESSAGE", "usageDirection": "OUTPUT", "description": "回复角色，固定为 assistant", "purpose": "标识这是模型的回复", "usageContext": "始终为 assistant"},
    {"fieldName": "output.message.content", "fieldPath": "output.message.content", "fieldType": "ARRAY", "required": true, "section": "MESSAGE", "usageDirection": "OUTPUT", "description": "回复内容块数组", "purpose": "承载模型生成的文本、工具调用等", "usageContext": "可包含 text、toolUse 类型的内容块"},
    {"fieldName": "stopReason", "fieldPath": "stopReason", "fieldType": "STRING", "required": true, "section": "MESSAGE", "usageDirection": "OUTPUT", "description": "停止原因：end_turn、max_tokens、stop_sequence、tool_use、content_filtered、guardrail_intervened", "purpose": "指示模型为何停止生成", "usageContext": "用于判断是否需要继续对话或执行工具"},
    {"fieldName": "content[].text", "fieldPath": "messages[].content[].text", "fieldType": "STRING", "required": false, "section": "CONTENT_BLOCK", "usageDirection": "INPUT", "description": "文本内容块", "purpose": "传递纯文本内容", "usageContext": "最基本的内容块类型"},
    {"fieldName": "content[].image", "fieldPath": "messages[].content[].image", "fieldType": "OBJECT", "required": false, "section": "CONTENT_BLOCK", "usageDirection": "INPUT", "description": "图片内容块", "purpose": "传入图片进行多模态推理", "usageContext": "包含 format（jpeg/png/gif/webp）和 source"},
    {"fieldName": "content[].image.format", "fieldPath": "messages[].content[].image.format", "fieldType": "STRING", "required": true, "section": "CONTENT_BLOCK", "usageDirection": "INPUT", "description": "图片格式：jpeg、png、gif、webp", "purpose": "指定图片编码格式", "usageContext": "必须与实际图片数据格式匹配"},
    {"fieldName": "content[].image.source.bytes", "fieldPath": "messages[].content[].image.source.bytes", "fieldType": "STRING", "required": true, "section": "CONTENT_BLOCK", "usageDirection": "INPUT", "description": "Base64 编码的图片数据", "purpose": "传递图片的实际数据", "usageContext": "Bedrock 仅支持 bytes 方式（非 URL）"},
    {"fieldName": "content[].document", "fieldPath": "messages[].content[].document", "fieldType": "OBJECT", "required": false, "section": "CONTENT_BLOCK", "usageDirection": "INPUT", "description": "文档内容块", "purpose": "传入 PDF/文档进行分析", "usageContext": "包含 format、name、source"},
    {"fieldName": "content[].document.format", "fieldPath": "messages[].content[].document.format", "fieldType": "STRING", "required": true, "section": "CONTENT_BLOCK", "usageDirection": "INPUT", "description": "文档格式：pdf、csv、doc、docx、xls、xlsx、html、txt、md", "purpose": "指定文档类型", "usageContext": "必须与实际文档格式匹配"},
    {"fieldName": "content[].document.name", "fieldPath": "messages[].content[].document.name", "fieldType": "STRING", "required": true, "section": "CONTENT_BLOCK", "usageDirection": "INPUT", "description": "文档名称", "purpose": "标识文档", "usageContext": "用于模型引用"},
    {"fieldName": "content[].document.source.bytes", "fieldPath": "messages[].content[].document.source.bytes", "fieldType": "STRING", "required": true, "section": "CONTENT_BLOCK", "usageDirection": "INPUT", "description": "Base64 编码的文档数据", "purpose": "传递文档的实际数据", "usageContext": "文档以 base64 形式内联传递"},
    {"fieldName": "inferenceConfig", "fieldPath": "inferenceConfig", "fieldType": "OBJECT", "required": false, "section": "MODEL", "usageDirection": "INPUT", "description": "推理配置对象", "purpose": "控制模型生成行为", "usageContext": "包含 maxTokens、temperature、topP、stopSequences"},
    {"fieldName": "inferenceConfig.maxTokens", "fieldPath": "inferenceConfig.maxTokens", "fieldType": "INTEGER", "required": false, "section": "MODEL", "usageDirection": "INPUT", "description": "最大输出 token 数", "purpose": "限制模型生成的最大长度", "usageContext": "嵌套在 inferenceConfig 中"},
    {"fieldName": "inferenceConfig.temperature", "fieldPath": "inferenceConfig.temperature", "fieldType": "FLOAT", "required": false, "section": "MODEL", "usageDirection": "INPUT", "description": "采样温度", "purpose": "控制输出随机性", "usageContext": "嵌套在 inferenceConfig 中"},
    {"fieldName": "inferenceConfig.topP", "fieldPath": "inferenceConfig.topP", "fieldType": "FLOAT", "required": false, "section": "MODEL", "usageDirection": "INPUT", "description": "核采样概率阈值", "purpose": "控制候选 token 的概率分布截断", "usageContext": "嵌套在 inferenceConfig 中"},
    {"fieldName": "inferenceConfig.stopSequences", "fieldPath": "inferenceConfig.stopSequences", "fieldType": "ARRAY", "required": false, "section": "MODEL", "usageDirection": "INPUT", "description": "停止序列列表", "purpose": "模型遇到这些序列时停止生成", "usageContext": "嵌套在 inferenceConfig 中"},
    {"fieldName": "additionalModelRequestFields", "fieldPath": "additionalModelRequestFields", "fieldType": "OBJECT", "required": false, "section": "MODEL", "usageDirection": "INPUT", "description": "模型特定的额外请求参数", "purpose": "传递特定模型的非标准参数", "usageContext": "如 Claude 的 top_k、thinking 等通过此字段传入"},
    {"fieldName": "additionalModelRequestFields.thinking", "fieldPath": "additionalModelRequestFields.thinking", "fieldType": "OBJECT", "required": false, "section": "MODEL", "usageDirection": "INPUT", "description": "Claude 扩展思维配置（via additionalModelRequestFields）", "purpose": "启用 Claude 模型的 extended thinking", "usageContext": "包含 type、budget_tokens 字段"},
    {"fieldName": "toolConfig", "fieldPath": "toolConfig", "fieldType": "OBJECT", "required": false, "section": "TOOL", "usageDirection": "INPUT", "description": "工具配置对象", "purpose": "声明可用工具和工具选择策略", "usageContext": "包含 tools 数组和 toolChoice 字段"},
    {"fieldName": "toolConfig.tools", "fieldPath": "toolConfig.tools", "fieldType": "ARRAY", "required": false, "section": "TOOL", "usageDirection": "INPUT", "description": "工具定义列表", "purpose": "声明模型可调用的工具", "usageContext": "每个工具包含 toolSpec"},
    {"fieldName": "toolConfig.tools[].toolSpec.name", "fieldPath": "toolConfig.tools[].toolSpec.name", "fieldType": "STRING", "required": true, "section": "TOOL", "usageDirection": "INPUT", "description": "工具名称", "purpose": "唯一标识工具", "usageContext": "模型在调用时引用此名称"},
    {"fieldName": "toolConfig.tools[].toolSpec.description", "fieldPath": "toolConfig.tools[].toolSpec.description", "fieldType": "STRING", "required": false, "section": "TOOL", "usageDirection": "INPUT", "description": "工具描述", "purpose": "帮助模型理解何时使用此工具", "usageContext": "描述工具的功能和适用场景"},
    {"fieldName": "toolConfig.tools[].toolSpec.inputSchema", "fieldPath": "toolConfig.tools[].toolSpec.inputSchema", "fieldType": "OBJECT", "required": true, "section": "TOOL", "usageDirection": "INPUT", "description": "工具输入参数 JSON Schema", "purpose": "定义工具输入参数结构", "usageContext": "包含 json 字段，值为标准 JSON Schema"},
    {"fieldName": "toolConfig.toolChoice", "fieldPath": "toolConfig.toolChoice", "fieldType": "OBJECT", "required": false, "section": "TOOL", "usageDirection": "INPUT", "description": "工具选择策略", "purpose": "控制模型如何选择工具", "usageContext": "可为 auto、any、tool（指定工具名）"},
    {"fieldName": "toolConfig.toolChoice.auto", "fieldPath": "toolConfig.toolChoice.auto", "fieldType": "OBJECT", "required": false, "section": "TOOL", "usageDirection": "INPUT", "description": "自动工具选择", "purpose": "模型自主决定是否使用工具", "usageContext": "空对象 {} 表示启用自动选择"},
    {"fieldName": "toolConfig.toolChoice.any", "fieldPath": "toolConfig.toolChoice.any", "fieldType": "OBJECT", "required": false, "section": "TOOL", "usageDirection": "INPUT", "description": "强制使用任意工具", "purpose": "模型必须调用至少一个工具", "usageContext": "空对象 {} 表示强制调用工具"},
    {"fieldName": "toolConfig.toolChoice.tool", "fieldPath": "toolConfig.toolChoice.tool", "fieldType": "OBJECT", "required": false, "section": "TOOL", "usageDirection": "INPUT", "description": "强制使用指定工具", "purpose": "模型必须调用指定的工具", "usageContext": "包含 name 字段指定工具名"},
    {"fieldName": "content[].toolUse", "fieldPath": "output.message.content[].toolUse", "fieldType": "OBJECT", "required": false, "section": "TOOL", "usageDirection": "OUTPUT", "description": "工具调用内容块", "purpose": "承载模型发起的工具调用", "usageContext": "包含 toolUseId、name、input"},
    {"fieldName": "content[].toolUse.toolUseId", "fieldPath": "output.message.content[].toolUse.toolUseId", "fieldType": "STRING", "required": true, "section": "TOOL", "usageDirection": "OUTPUT", "description": "工具调用唯一标识", "purpose": "关联工具调用与结果", "usageContext": "用于在后续 toolResult 中引用"},
    {"fieldName": "content[].toolUse.name", "fieldPath": "output.message.content[].toolUse.name", "fieldType": "STRING", "required": true, "section": "TOOL", "usageDirection": "OUTPUT", "description": "被调用的工具名称", "purpose": "标识模型选择调用的工具", "usageContext": "匹配 toolSpec.name"},
    {"fieldName": "content[].toolUse.input", "fieldPath": "output.message.content[].toolUse.input", "fieldType": "OBJECT", "required": true, "section": "TOOL", "usageDirection": "OUTPUT", "description": "工具调用输入参数（JSON 对象）", "purpose": "传递模型生成的工具输入参数", "usageContext": "直接为 JSON 对象（非字符串）"},
    {"fieldName": "content[].toolResult", "fieldPath": "messages[].content[].toolResult", "fieldType": "OBJECT", "required": false, "section": "TOOL", "usageDirection": "INPUT", "description": "工具执行结果内容块", "purpose": "将工具执行结果传回模型", "usageContext": "包含 toolUseId、content、status"},
    {"fieldName": "content[].toolResult.toolUseId", "fieldPath": "messages[].content[].toolResult.toolUseId", "fieldType": "STRING", "required": true, "section": "TOOL", "usageDirection": "INPUT", "description": "对应的工具调用 ID", "purpose": "关联工具结果与原始调用", "usageContext": "匹配 toolUse.toolUseId"},
    {"fieldName": "content[].toolResult.content", "fieldPath": "messages[].content[].toolResult.content", "fieldType": "ARRAY", "required": true, "section": "TOOL", "usageDirection": "INPUT", "description": "工具结果内容块数组", "purpose": "承载工具执行的返回内容", "usageContext": "可包含 text、image、document 等内容块"},
    {"fieldName": "content[].toolResult.status", "fieldPath": "messages[].content[].toolResult.status", "fieldType": "STRING", "required": false, "section": "TOOL", "usageDirection": "INPUT", "description": "工具执行状态：success、error", "purpose": "告知模型工具是否执行成功", "usageContext": "error 时模型会尝试其他方案"},
    {"fieldName": "stream (ConverseStream)", "fieldPath": "stream", "fieldType": "BOOLEAN", "required": false, "section": "STREAMING", "usageDirection": "INPUT", "description": "是否使用流式端点", "purpose": "通过选择 ConverseStream 操作启用", "usageContext": "Bedrock 通过不同的 API 操作（Converse vs ConverseStream）而非请求参数控制流式"},
    {"fieldName": "stream.messageStart", "fieldPath": "streaming.messageStart", "fieldType": "OBJECT", "required": false, "section": "STREAMING", "usageDirection": "OUTPUT", "description": "消息开始事件", "purpose": "通知流式响应开始", "usageContext": "包含 role 字段"},
    {"fieldName": "stream.contentBlockStart", "fieldPath": "streaming.contentBlockStart", "fieldType": "OBJECT", "required": false, "section": "STREAMING", "usageDirection": "OUTPUT", "description": "内容块开始事件", "purpose": "通知新内容块开始", "usageContext": "包含 contentBlockIndex 和 start（toolUse 时含 toolUseId/name）"},
    {"fieldName": "stream.contentBlockDelta", "fieldPath": "streaming.contentBlockDelta", "fieldType": "OBJECT", "required": false, "section": "STREAMING", "usageDirection": "OUTPUT", "description": "内容块增量事件", "purpose": "流式传输内容增量", "usageContext": "delta 可为 text 或 toolUse.input 的 JSON 片段"},
    {"fieldName": "stream.contentBlockStop", "fieldPath": "streaming.contentBlockStop", "fieldType": "OBJECT", "required": false, "section": "STREAMING", "usageDirection": "OUTPUT", "description": "内容块结束事件", "purpose": "通知某个内容块完成", "usageContext": "包含 contentBlockIndex"},
    {"fieldName": "stream.messageStop", "fieldPath": "streaming.messageStop", "fieldType": "OBJECT", "required": false, "section": "STREAMING", "usageDirection": "OUTPUT", "description": "消息结束事件", "purpose": "通知流式响应结束", "usageContext": "包含 stopReason"},
    {"fieldName": "stream.metadata", "fieldPath": "streaming.metadata", "fieldType": "OBJECT", "required": false, "section": "STREAMING", "usageDirection": "OUTPUT", "description": "流式元数据事件", "purpose": "流末尾返回 usage 和 metrics", "usageContext": "包含 usage 和 metrics 信息"},
    {"fieldName": "usage", "fieldPath": "usage", "fieldType": "OBJECT", "required": true, "section": "USAGE", "usageDirection": "OUTPUT", "description": "Token 用量统计", "purpose": "报告请求消耗的 token 数量", "usageContext": "包含 inputTokens、outputTokens、totalTokens"},
    {"fieldName": "usage.inputTokens", "fieldPath": "usage.inputTokens", "fieldType": "INTEGER", "required": true, "section": "USAGE", "usageDirection": "OUTPUT", "description": "输入 token 数", "purpose": "计算输入消耗", "usageContext": "包含所有输入内容的 token 数"},
    {"fieldName": "usage.outputTokens", "fieldPath": "usage.outputTokens", "fieldType": "INTEGER", "required": true, "section": "USAGE", "usageDirection": "OUTPUT", "description": "输出 token 数", "purpose": "计算输出消耗", "usageContext": "模型生成的 token 数量"},
    {"fieldName": "usage.totalTokens", "fieldPath": "usage.totalTokens", "fieldType": "INTEGER", "required": true, "section": "USAGE", "usageDirection": "OUTPUT", "description": "总 token 数", "purpose": "输入 + 输出的总计", "usageContext": "inputTokens + outputTokens"},
    {"fieldName": "usage.cacheReadInputTokens", "fieldPath": "usage.cacheReadInputTokens", "fieldType": "INTEGER", "required": false, "section": "USAGE", "usageDirection": "OUTPUT", "description": "缓存读取的输入 token 数", "purpose": "报告从 prompt 缓存命中的 token 量", "usageContext": "Claude 模型通过 Bedrock 返回的缓存统计"},
    {"fieldName": "usage.cacheWriteInputTokens", "fieldPath": "usage.cacheWriteInputTokens", "fieldType": "INTEGER", "required": false, "section": "USAGE", "usageDirection": "OUTPUT", "description": "缓存写入的输入 token 数", "purpose": "报告写入 prompt 缓存的 token 量", "usageContext": "首次缓存时产生额外费用"},
    {"fieldName": "requestMetadata", "fieldPath": "requestMetadata", "fieldType": "OBJECT", "required": false, "section": "METADATA", "usageDirection": "INPUT", "description": "请求元数据", "purpose": "附加请求上下文信息", "usageContext": "键值对形式"},
    {"fieldName": "guardrailConfig", "fieldPath": "guardrailConfig", "fieldType": "OBJECT", "required": false, "section": "METADATA", "usageDirection": "INPUT", "description": "Guardrails 配置", "purpose": "启用 AWS Bedrock Guardrails 内容过滤", "usageContext": "包含 guardrailIdentifier、guardrailVersion、trace"},
    {"fieldName": "guardrailConfig.guardrailIdentifier", "fieldPath": "guardrailConfig.guardrailIdentifier", "fieldType": "STRING", "required": true, "section": "METADATA", "usageDirection": "INPUT", "description": "Guardrail 标识符", "purpose": "指定使用哪个 Guardrail", "usageContext": "Guardrail 的 ID 或 ARN"},
    {"fieldName": "guardrailConfig.guardrailVersion", "fieldPath": "guardrailConfig.guardrailVersion", "fieldType": "STRING", "required": true, "section": "METADATA", "usageDirection": "INPUT", "description": "Guardrail 版本", "purpose": "指定 Guardrail 的版本", "usageContext": "版本号或 DRAFT"},
    {"fieldName": "metrics", "fieldPath": "metrics", "fieldType": "OBJECT", "required": false, "section": "METADATA", "usageDirection": "OUTPUT", "description": "请求性能指标", "purpose": "报告延迟等性能数据", "usageContext": "包含 latencyMs 字段"},
    {"fieldName": "metrics.latencyMs", "fieldPath": "metrics.latencyMs", "fieldType": "INTEGER", "required": false, "section": "METADATA", "usageDirection": "OUTPUT", "description": "请求延迟（毫秒）", "purpose": "报告端到端延迟", "usageContext": "从请求到首字节或完整响应的时间"},
    {"fieldName": "additionalModelResponseFields", "fieldPath": "additionalModelResponseFields", "fieldType": "OBJECT", "required": false, "section": "METADATA", "usageDirection": "OUTPUT", "description": "模型特定的额外响应字段", "purpose": "返回特定模型的非标准响应数据", "usageContext": "如 Claude 的 stop_sequence 等通过此字段返回"},
    {"fieldName": "trace", "fieldPath": "trace", "fieldType": "OBJECT", "required": false, "section": "METADATA", "usageDirection": "OUTPUT", "description": "Guardrails 追踪信息", "purpose": "返回 Guardrail 的评估结果详情", "usageContext": "仅在配置了 guardrailConfig.trace=enabled 时返回"}
  ]
}
