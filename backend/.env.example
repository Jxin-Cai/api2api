SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/api2api
SPRING_DATASOURCE_USERNAME=api2api
SPRING_DATASOURCE_PASSWORD=api2api
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# 用于加密保存 API Key 明文材料，生产环境请设置为足够长的随机密钥并妥善备份。
API2API_API_KEY_ENCRYPTION_KEY=change-me-api-key-material-secret
# Docker 环境下访问宿主机 localhost/127.0.0.1 上游服务时使用；留空则不改写。
API2API_UPSTREAM_HOST_OVERRIDE=host.docker.internal
