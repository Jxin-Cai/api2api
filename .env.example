# Docker Compose image overrides.
# If Docker Hub is unavailable, switch these to a reachable registry mirror, for example:
#   docker.m.daocloud.io/library/node:22-alpine
#   docker.m.daocloud.io/library/nginx:1.27-alpine
#   docker.m.daocloud.io/library/postgres:16-alpine
#   docker.m.daocloud.io/library/maven:3.9.9-eclipse-temurin-17
#   docker.m.daocloud.io/library/eclipse-temurin:17-jre
NODE_IMAGE=node:22-alpine
NGINX_IMAGE=nginx:1.27-alpine
POSTGRES_IMAGE=postgres:16-alpine
MAVEN_IMAGE=maven:3.9.9-eclipse-temurin-17
JRE_IMAGE=eclipse-temurin:17-jre
