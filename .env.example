# Project runtime configuration for Docker Compose.
# Docker image versions are maintained in docker-compose.yml and Dockerfiles,
# not in environment files.
POSTGRES_DB=api2api
POSTGRES_USER=api2api
POSTGRES_PASSWORD=api2api
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
FRONTEND_PORT=8989

# Gateway and provider timeouts for long-running Claude/Bedrock streams.
API2API_GATEWAY_ASYNC_TIMEOUT=15m
API2API_UPSTREAM_READ_TIMEOUT=10m
API2API_STREAMING_FIRST_BYTE_TIMEOUT=2m
API2API_STREAMING_IDLE_TIMEOUT=10m
# Docker 环境下访问宿主机 localhost/127.0.0.1 上游服务时使用；留空则不改写。
API2API_UPSTREAM_HOST_OVERRIDE=host.docker.internal
